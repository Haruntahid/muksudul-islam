{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "cp artifacts/portfolio/src/data/portfolioSource.json artifacts/api-server/src/data/portfolioSource.json && pnpm --filter @workspace/portfolio run build && node build-vercel-api.mjs",
  "outputDirectory": "artifacts/portfolio/dist/public",
  "framework": null,
  "env": {
    "PORT": "5173",
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
